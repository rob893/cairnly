{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5180",
      "https://localhost:5180",
      "http://127.0.0.1:5180",
      "https://127.0.0.1:5180"
    ],
    "ExposedHeaders": [
      "X-Token-Expired",
      "X-Correlation-Id",
      "X-Rate-Limit-Limit",
      "X-Rate-Limit-Remaining",
      "X-Rate-Limit-Reset"
    ]
  },
  "Email": {
    "FromAddress": "DoNotReply@cairnly.local",
    "AcsEndpoint": "https://rherber-acs-g-d.unitedstates.communication.azure.com",
    "Enabled": false
  },
  "Authentication": {
    "TokenAudience": "cairnly",
    "TokenIssuer": "cairnly",
    "TokenExpirationTimeInMinutes": 60,
    "RefreshTokenExpirationTimeInMinutes": 43200,
    "GoogleOAuthAudiences": [],
    "CookieDomain": null
  },
  "KeyVaultUrl": "https://rherber-kv-ue-d.vault.azure.net",
  "OpenApi": {
    "Enabled": true,
    "SupportedApiVersions": ["v1"],
    "AuthSettings": {
      "RequireAuth": true
    }
  },
  "Postgres": {
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "ForwardedHeaders": {
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": [],
    "AllowedForwardedPrefixes": []
  }
}
