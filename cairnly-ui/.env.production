# Production build config (npm run build), deployed to GitHub Pages. Non-secret —
# bundled into the browser. Read automatically by Vite; no CI variable needed.
# To deploy against a different API origin, add another .env.<mode> file and build
# with `vite build --mode <mode>`.
VITE_API_BASE_URL=https://api.cairnlyfinance.com/
VITE_BASE_PATH=/
